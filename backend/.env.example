# --- CORS ---
# Адреса фронтенда через запятую. Для локалки оставьте как есть.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Почта ---
# Куда приходит заявка с формы.
OWNER_EMAIL=freezar@mail.ru
# От кого отправляются письма (обычно совпадает с SMTP_USER).
SMTP_FROM=freezar@mail.ru
# SMTP-сервер. Примеры:
#   mail.ru:   smtp.mail.ru   порт 465 (SSL)
#   gmail:     smtp.gmail.com порт 465 (SSL) или 587 (STARTTLS), нужен app-password
#   yandex:    smtp.yandex.ru порт 465 (SSL)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# true = SSL (порт 465), false = STARTTLS (порт 587)
SMTP_SSL=true
# Если SMTP_HOST пуст — письма не отправляются, а печатаются в консоль
# (dry-run), чтобы можно было проверить весь цикл формы без почты.

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-haiku-latest
