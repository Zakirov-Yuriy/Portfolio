# Базовый URL backend. Пусто = относительный путь /api (работает с Vite-прокси в dev
# и с rewrite на хостинге). В проде укажи адрес деплоя FastAPI, например:
# VITE_API_BASE_URL=https://yuri-portfolio-api.onrender.com
VITE_API_BASE_URL=

# Куда Vite-прокси перенаправляет /api в режиме разработки.
VITE_DEV_API_TARGET=http://127.0.0.1:8000
